// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_edit_predictions": true,
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-opus-4-5",
    },
    "model_parameters": [],
  },
  "vim_mode": false,
  "terminal": {
    "env": {
      "EDITOR": "zed --wait",
    },
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "auto",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "languages": {
    "Git Commit": {
      "wrap_guides": [50, 72],
      "preferred_line_length": 72,
    },
  },
  "wrap_guides": [50, 72, 80],
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
}
